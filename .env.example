# --- Inference (Nebius Token Factory) ----------------------------------------
# Required for the agent step.
NEBIUS_API_KEY=XXX

# --- Docker Compose deployment ------------------------------------------------
# Absolute path of this repo ON THE DOCKER HOST. DockerOperator bind-mounts
# reference host paths, so this must be the real path on the VM (e.g.
# /home/user/mlops-assignment-e2e-ml-pipeline). On `export HOST_PROJECT_DIR=$(pwd)`.
HOST_PROJECT_DIR=/opt/airflow
# Image built from the project Dockerfile and used by the DockerOperator DAG:
#   docker build -t mlops-assignment:latest .
AGENT_IMAGE=mlops-assignment:latest

# --- MLflow -------------------------------------------------------------------
# In Compose this points at the bundled MLflow service. For the standalone path
# leave it unset to use a local ./mlruns store, or point it at a running server.
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=coding-agent-eval

# --- Object Storage (optional, S3-compatible e.g. Nebius) ---------------------
# Artifact upload is skipped entirely when S3_BUCKET is empty.
S3_BUCKET=
S3_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud:443
S3_PREFIX=runs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north1
